{
  "name": "familymarkup",
  "displayName": "FamilyMarkup",
  "description": "Full-featured support of FamilyMarkup language",
  "icon": "icon.png",
  "version": "2.1.0",
  "repository": "github:redexp/vscode-familymarkup",
  "main": "./client/extension",
  "browser": "./dist/web.js",
  "license": "BSD-4-Clause",
  "publisher": "FamilyMarkup",
  "scripts": {
    "build": "vsce package",
    "publish": "vsce publish",
    "compile-web": "webpack",
    "watch-web": "webpack --watch",
    "package-web": "webpack --mode production --devtool hidden-source-map"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "markdown.markdownItPlugins": false,
    "languages": [
      {
        "id": "familymarkup",
        "aliases": [
          "FamilyMarkup",
          "family",
          "FML"
        ],
        "extensions": [
          ".fml",
          ".family"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/file-light.png",
          "dark": "./icons/file-dark.png"
        }
      },
      {
        "id": "familymarkup-markdown-injection"
      }
    ],
    "grammars": [
      {
        "language": "familymarkup",
        "scopeName": "source.family",
        "path": "./syntaxes/familymarkup.tmLanguage.json"
      },
      {
        "language": "familymarkup-markdown-injection",
        "scopeName": "markdown.family.codeblock",
        "path": "./syntaxes/familymarkup-markdown-injection.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.family": "familymarkup"
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "families",
          "name": "Families"
        }
      ]
    },
    "configuration": {
      "title": "FamilyMarkup",
      "properties": {
        "familymarkup.locale": {
          "type": "string",
          "default": "editor",
          "enum": [
            "editor",
            "uk",
            "ru",
            "en"
          ],
          "enumItemLabels": [
            "Current editor locale",
            "Українська",
            "Русский",
            "English"
          ]
        },
        "familymarkup.childrenWithoutRelationships": {
          "type": "boolean",
          "default": true,
          "description": "Usually, when a family starts with a large number of siblings, it’s easy to overlook describing the branch of one of them. This feature will highlight all children who lack family connections, allowing you to check whether a person truly did not continue the lineage or if you simply forgot to describe their branch."
        }
      }
    },
    "configurationDefaults": {
      "[familymarkup]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.formatOnType": true,
        "editor.quickSuggestions": {
          "strings": true
        }
      }
    },
    "commands": [
      {
        "command": "familymarkup.showGraph",
        "title": "Open Family Tree View",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "familymarkup.showGraph",
          "group": "navigation",
          "when": "editorLangId == familymarkup"
        }
      ]
    }
  },
  "extensionDependencies": [
    "ms-vscode.wasm-wasi-core"
  ],
  "dependencies": {
    "@vscode/wasm-wasi-lsp": "^0.1.0-pre.9",
    "shiki": "^3.23.0",
    "vscode-languageclient": "^10.0.0-next.21",
    "vscode-shiki-bridge": "^0.5.2"
  },
  "devDependencies": {
    "@svgdotjs/svg.js": "^3.2.5",
    "@tsconfig/bun": "^1.0.10",
    "@types/vscode": "^1.90.0",
    "@types/vscode-webview": "^1.57.5",
    "less": "^4.4.1",
    "process": "^0.11.10",
    "svg-pan-zoom": "^3.6.2",
    "svg-round-corners": "^0.4.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "ws": "^8.18.0"
  }
}
